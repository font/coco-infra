# Bare metal cluster configuration
# Copy to config.env and fill in your values:
#   cp config.env.example config.env

# Cluster
CLUSTER_NAME=coco
BASE_DOMAIN=example.com
MACHINE_NETWORK=192.168.1.0/24

# Host
RENDEZVOUS_IP=192.168.1.10
HOST_NAME=my-host
ROOT_DEVICE=/dev/nvme0n1
IFACE_NAME=eth0
IFACE_MAC=00:00:00:00:00:00
